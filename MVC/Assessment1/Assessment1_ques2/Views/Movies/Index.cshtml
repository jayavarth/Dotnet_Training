@model IEnumerable<Assessment1_ques2.Models.Movie>

<h2>All Movies</h2>

<table border="1">
<tr>
    <th>Name</th>
    <th>Director</th>
    <th>Release Date</th>
    <th>Actions</th>
</tr>

@foreach (var m in Model)
{
<tr>
    <td>@m.Moviename</td>
    <td>@m.DirectorName</td>
    <td>@m.DateofRelease</td>
    <td>
        @Html.ActionLink("Edit","Edit", new { id = m.Mid }) |
        @Html.ActionLink("Delete","Delete", new { id = m.Mid })
    </td>
</tr>
}
</table>
